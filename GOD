local function GetGitSound(GithubSnd, SoundName)
	local fileName = SoundName .. ".mp3"
	if isfile and not isfile(fileName) then
		pcall(function()
			writefile(fileName, game:HttpGet(GithubSnd))
		end)
	end

	local getasset = getcustomasset or getsynasset
	if getasset and isfile and isfile(fileName) then
		local sound = Instance.new("Sound")
		sound.SoundId = getasset(fileName)
		return sound
	end
	return nil
end

