local rng = Random.new()

entity:SetCallback("OnEnterRoom", function(room: Model, firstTime: boolean)
	local chance = rng:NextInteger(95, 100) 

	if firstTime == true then
		if chance == 100 then
			local RunService = game:GetService("RunService")
			local TweenService = game:GetService("TweenService")

			local entityModel = workspace:FindFirstChild("GloomMoving")
			local entityRoot = entityModel and (entityModel:FindFirstChild("HumanoidRootPart") or entityModel:FindFirstChildWhichIsA("BasePart")) 

			if entityRoot then
				local freezeConnection
				local doorFreezePos = entityRoot.CFrame
				
				for _, descendant in ipairs(entityRoot:GetDescendants()) do
					if descendant:IsA("Sound") then
						descendant.Playing = false
					end
				end
				
			 entity.Config.CameraShake.Enabled = false
				entity.Config.Damage.Enabled = false

				freezeConnection = RunService.Heartbeat:Connect(function()
					if entityModel and entityModel.Parent and entityRoot then
						entityRoot.Anchored = true
						entityRoot.CFrame = doorFreezePos
						entityRoot.AssemblyLinearVelocity = Vector3.zero
						entityRoot.AssemblyAngularVelocity = Vector3.zero
					end
				end)

				local gloom6 = Instance.new("Sound")
				gloom6.PlaybackSpeed = 1
				gloom6.Volume = 10
				gloom6.SoundId = "rbxassetid://6543930617"
				gloom6.Parent = workspace
				gloom6:Play()

				task.wait(0.2)

				TweenService:Create(
					gloom6,
					TweenInfo.new(3, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
					{ PlaybackSpeed = 0.029 }
				):Play()

				task.wait(2)

				local gloom21 = Instance.new("Sound")
				gloom21.PlaybackSpeed = 0.7
				gloom21.Volume = 15
				gloom21.SoundId = "rbxassetid://1116768946"
				gloom21.Parent = workspace
				gloom21:Play()

				local dis1 = Instance.new('DistortionSoundEffect')
				dis1.Parent = gloom21

				task.wait(0.1)

				TweenService:Create(
					gloom21,
					TweenInfo.new(3, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
					{ PlaybackSpeed = 0 }
				):Play()

				task.wait(2.5)
				
				local CameraShaker = require(game.ReplicatedStorage.CameraShaker)
				local camara = game.Workspace.CurrentCamera

				local camShake = CameraShaker.new(Enum.RenderPriority.Camera.Value, function(shakeCf)
					camara.CFrame = camara.CFrame * shakeCf
				end)

				camShake:Start()
				camShake:ShakeOnce(20, 6, 1, 10, 2, 2)

				local gloom = Instance.new("Sound")
				gloom.PlaybackSpeed = 0
				gloom.Volume = 10
				gloom.SoundId = "rbxassetid://1116768946"
				gloom.Parent = workspace
				gloom:Play()

				local dis2 = Instance.new('DistortionSoundEffect')
				dis2.Parent = gloom
				dis2.Level = 0

				task.wait(0.2)

				TweenService:Create(
					gloom,
					TweenInfo.new(10, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
					{ PlaybackSpeed = 0.7 }
				):Play()

				TweenService:Create(
					dis2,
					TweenInfo.new(10, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
					{ Level = 0.8 }
				):Play()

				local gloom2 = Instance.new("Sound")
				gloom2.PlaybackSpeed = 0.029
				gloom2.Volume = 15
				gloom2.SoundId = "rbxassetid://6543930617"
				gloom2.Parent = workspace
				gloom2:Play()

				local dis3 = Instance.new('DistortionSoundEffect')
				dis3.Parent = gloom2
				dis3.Level = 0.5

				task.wait(0.1)

				TweenService:Create(
					gloom2,
					TweenInfo.new(5, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
					{ PlaybackSpeed = 1 }
				):Play()

				task.wait(9)

				if freezeConnection then
					freezeConnection:Disconnect()
				end
				
				for _, descendant in ipairs(entityRoot:GetDescendants()) do
					if descendant:IsA("Sound") then
						descendant.Playing = true
					end
				end

				gloom2:Destroy()
				gloom:Destroy()
				gloom21:Destroy()
				gloom6:Destroy()
				
				entity.Config.CameraShake.Enabled = true
				entity.Config.Damage.Enabled = true
				
			end
		end
		print("Entity has entered room: ".. room.Name.. " for the first time (Chance rolled: " .. chance .. ")")
	else
		print("Entity has entered room: ".. room.Name.. " again (Chance rolled: " .. chance .. ")")
	end
end)

