-- === Hàm đổi màu đèn trong phòng ===
function light(tim, color0, color1)
	local tweenservice = game:GetService("TweenService")
	local info = TweenInfo.new(tim, Enum.EasingStyle.Linear)
	for _, l in pairs(game.Workspace.CurrentRooms:GetDescendants()) do
		if l:IsA("Light") or l:IsA("SurfaceLight") or l:IsA("SpotLight") then
			tweenservice:Create(l, info, {Color = color1}):Play()
		end
		if l:IsA("MeshPart") and l.Material == Enum.Material.Neon and l.Name ~= "Skybox" then
			tweenservice:Create(l, info, {Color = color0}):Play()
		end
	end
end

-- === Hàm spawn Halt (MultiHalt) ===
local function spawnHalt()
	local rooms = workspace.CurrentRooms
	local notcureect = rooms:FindFirstChild(tostring(game.ReplicatedStorage.GameData.LatestRoom.Value - 1))
	local multihalt = "https://github.com/eoyoustme/Script/raw/main/Multimonster.rbxm"

	local function getgithubmodeL(url)
		if not (writefile and getcustomasset and request) then return nil end
		local fileName = string.match(url, "([^/]+)$") or "temp_model.rbxm"
		local response = request({Url = url, Method = "GET"})
		if response.StatusCode ~= 200 then return nil end
		writefile(fileName, response.Body)
		local assetId = getcustomasset(fileName)
		local success, result = pcall(function() return game:GetObjects(assetId)[1] end)
		return success and result or nil
	end

	local CameraShaker = require(game.ReplicatedStorage.CameraShaker)
	local camera = game.Workspace.CurrentCamera
	local camShake = CameraShaker.new(Enum.RenderPriority.Camera.Value, function(shakeCf)
		camera.CFrame = camera.CFrame * shakeCf
	end)
	camShake:Start()
	camShake:ShakeOnce(10, 3.5, 0.1, 2, 1, 0.5)

	task.wait(1)

	local entity5 = getgithubmodeL(multihalt)
	if entity5 then entity5.Parent = workspace end

	local entity = workspace:FindFirstChild("multimonster") and workspace.multimonster:FindFirstChild("Multi")
	if not entity then return end

	entity.Anchored = true
	entity.CanCollide = false

	if notcureect and notcureect:FindFirstChild("Door") and notcureect.Door:FindFirstChild("Door") then
		entity.CFrame = notcureect.Door.Door.CFrame * CFrame.new(0, 0, -50)
	end

	local chr = player.Character or player.CharacterAdded:Wait()
	local hrp = chr:WaitForChild("HumanoidRootPart")

	-- Tự xóa Halt sau khi qua 2 phòng
	task.spawn(function()
		game.ReplicatedStorage.GameData.LatestRoom.Changed:Wait()
		game.ReplicatedStorage.GameData.LatestRoom.Changed:Wait()
		if entity and entity.Parent then
			entity:Destroy()
			if workspace:FindFirstChild("multimonster") then
				workspace.multimonster:Destroy()
			end
		end
	end)

	-- Vòng lặp gây sát thương
	threadb = task.spawn(function()
		while true do
			task.wait(0.2)
			if not entity or not entity.Parent then break end
			local char = player.Character
			local hum = char and char:FindFirstChildOfClass("Humanoid")
			local pHrp = char and char:FindFirstChild("HumanoidRootPart")

			if hum and pHrp and hum.Health > 0 then
				if (pHrp.Position - entity.Position).Magnitude <= 6 then
					hum.Health = 0
					local stats = game:GetService("ReplicatedStorage").GameStats:FindFirstChild("Player_" .. player.Name)
					if stats and stats:FindFirstChild("Total") then
						stats.Total.DeathCause.Value = "MultiHalt"
					end
					break
				end
			end
		end
	end)

	-- Vòng lặp di chuyển di chuyển giật tới/lui
	threaa = task.spawn(function()
		task.spawn(function()
			local screenGui = Instance.new("ScreenGui")
			screenGui.Name = "JumpscareOverlay"
			screenGui.IgnoreGuiInset = true
			screenGui.DisplayOrder = 999999
			screenGui.Parent = playerGui

			local imageLabel = Instance.new("ImageLabel")
			imageLabel.BackgroundTransparency = 1
			imageLabel.BorderSizePixel = 0
			imageLabel.Size = UDim2.new(1, 0, 1, 0)
			imageLabel.ScaleType = Enum.ScaleType.Stretch
			imageLabel.Parent = screenGui
			imageLabel.ImageColor3 = Color3.fromRGB(255, 0, 0)

			local jumpscareImages = {
				"rbxassetid://134346506410955",
				"rbxassetid://7578853379",
				"rbxassetid://103846711769666",
				"rbxassetid://78199392475572"
			}

			local duration = 1
			local start = os.clock()
			local imageIndex = 1

			local tween = TweenService:Create(imageLabel, TweenInfo.new(duration, Enum.EasingStyle.Linear), {ImageTransparency = 1})
			tween:Play()

			while os.clock() - start < duration do
				imageLabel.Image = jumpscareImages[imageIndex]
				imageIndex = (imageIndex % #jumpscareImages) + 1
				task.wait(0.03)
			end

			tween.Completed:Wait()
			screenGui:Destroy()
		end)

		while entity and entity.Parent and hrp do
			local startFollow = tick()
			while tick() - startFollow < 3 do
				if not entity or not entity.Parent or not hrp then break end
				local SPEED = 14
				local targetCFrame = hrp.CFrame
				local duration = (targetCFrame.Position - entity.Position).Magnitude / SPEED
				local tween = TweenService:Create(entity, TweenInfo.new(duration <= 0 and 0.05 or duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
				tween:Play()
				tween.Completed:Wait()
			end

			if not entity or not entity.Parent or not hrp then break end
			entity.CFrame = hrp.CFrame * CFrame.new(0, 0, -40)

			local SPEED_FRONT = 16
			local durationFront = (hrp.CFrame.Position - entity.Position).Magnitude / SPEED_FRONT
			local tweenFront = TweenService:Create(entity, TweenInfo.new(durationFront, Enum.EasingStyle.Linear), {CFrame = hrp.CFrame})
			tweenFront:Play()
			tweenFront.Completed:Wait()

			task.wait(1.5)
			if not entity or not entity.Parent or not hrp then break end

			entity.CFrame = hrp.CFrame * CFrame.new(0, 0, 30)
			local SPEED_BACK = 13
			local durationBack = (hrp.CFrame.Position - entity.Position).Magnitude / SPEED_BACK
			local tweenBack = TweenService:Create(entity, TweenInfo.new(durationBack, Enum.EasingStyle.Linear), {CFrame = hrp.CFrame})
			tweenBack:Play()
			tweenBack.Completed:Wait()

			task.wait(0.1)
		end
	end)
end

