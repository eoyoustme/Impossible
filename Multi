threaa = task.spawn(function()
	while entity and entity.Parent and hrp do
		
		-- Giai đoạn 1: Đuổi theo player trong 3 giây
		local startFollow = tick()
		while tick() - startFollow < 3 do
			if not entity or not entity.Parent or not hrp then break end

			local SPEED = 15
			local targetCFrame = hrp.CFrame
			local distance = (targetCFrame.Position - entity.Position).Magnitude
			local duration = distance / SPEED

			local tween = TweenService:Create(
				entity,
				TweenInfo.new(duration <= 0 and 0.05 or duration, Enum.EasingStyle.Linear),
				{CFrame = targetCFrame}
			)
			tween:Play()
			tween.Completed:Wait() 
		end

		if not entity or not entity.Parent or not hrp then break end

		-- Giai đoạn 2: Giật ra trước mặt 40 studs
		entity.CFrame = hrp.CFrame * CFrame.new(0, 0, -40)

		local SPEED_FRONT = 20
		local targetCFrameFront = hrp.CFrame
		local distanceFront = (targetCFrameFront.Position - entity.Position).Magnitude

		local tweenFront = TweenService:Create(
			entity,
			TweenInfo.new(distanceFront / SPEED_FRONT, Enum.EasingStyle.Linear),
			{CFrame = targetCFrameFront}
		)
		tweenFront:Play()
		tweenFront.Completed:Wait() 

		task.wait(1.5)
		if not entity or not entity.Parent or not hrp then break end

		-- Giai đoạn 3: Giật ra sau lưng 30 studs
		entity.CFrame = hrp.CFrame * CFrame.new(0, 0, 30) 

		local SPEED_BACK = 15
		local targetCFrameBack = hrp.CFrame
		local distanceBack = (targetCFrameBack.Position - entity.Position).Magnitude

		local tweenBack = TweenService:Create(
			entity,
			TweenInfo.new(distanceBack / SPEED_BACK, Enum.EasingStyle.Linear),
			{CFrame = targetCFrameBack}
		)
		tweenBack:Play()
		tweenBack.Completed:Wait() 

		task.wait(0.1) 
	end
end)

