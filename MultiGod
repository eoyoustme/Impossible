		local jumpscareImage2 = "rbxassetid://7578853379"
		local jumpscareImage3 = "rbxassetid://103846711769666"
		local jumpscareImage4 = "rbxassetid://78199392475572"

		local flashDuration = 350
		local start = tick()

		while tick() - start < flashDuration do
			imageLabel.Image = jumpscareImage1
