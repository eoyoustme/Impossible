entity:SetCallback("OnDamagePlayer", function(newHealth: number)
	if newHealth <= 0 then
		print("Entity has killed the player")
	else
		print("Entity has damaged the player")

		local model = workspace:WaitForChild("MultiGod")
		local part = model:FindFirstChild("Multi") or model:FindFirstChildWhichIsA("BasePart")
		if not part then return end

		local chr = player.Character or player.CharacterAdded:Wait()
		local hrp = chr:WaitForChild("HumanoidRootPart")

		part.Anchored = true

		local SPEED_STUDS_PER_SECOND = 23
		local targetCFrame = hrp.CFrame
		local distance = (targetCFrame.Position - part.Position).Magnitude
		local duration = distance / SPEED_STUDS_PER_SECOND

		if duration <= 0 then
			duration = 0.05
		end


		local tween = TweenService:Create(
			part,
			TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut),
			{CFrame = targetCFrame}
		)

		tween:Play()

		local function GetGitSound(GithubSnd, SoundName)
			local url = GithubSnd
			if not isfile(SoundName .. ".ogg") then
				writefile(SoundName .. ".ogg", game:HttpGet(url))
			end
			local sound = Instance.new("Sound")
			sound.SoundId = (getcustomasset or getsynasset)(SoundName .. ".ogg")
			return sound
		end

		local blueSound = game.Workspace.Your

		local gitSoundTemp = GetGitSound("https://github.com/eoyoustme/Hardcore/blob/main/Your_Consenting_Mind_clean.ogg?raw=true", "quyenluc")

		blueSound.SoundId = gitSoundTemp.SoundId

		gitSoundTemp:Destroy()

		tween.Completed:Wait()
	end
end)

