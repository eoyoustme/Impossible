entity:SetCallback("OnDespawning", function()
	print("Entity is despawning")

	local deer = workspace:FindFirstChild("MultiGod")
	if deer then deer:Destroy() end

	if threadA then
		task.cancel(threadA)
		threadA = nil
	end
	if threadB then
		task.cancel(threadB)
		threadB = nil
	end

	task.spawn(function()
		if caption then
			caption.TextTransparency = 0
			caption.Visible = true

			local info = TweenInfo.new(5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
			local tween = TweenService:Create(caption, info, {TextTransparency = 1})
			tween:Play()
		end
	end)

	local anhguoc = player:WaitForChild("PlayerGui")
	local cac = anhguoc:FindFirstChild("JumpscareOverlay")
	if cac then
		cac:Destroy()
	end

	if Lord then Lord:Destroy() end
end)

