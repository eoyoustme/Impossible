entity:SetCallback("OnRebounding", function(startOfRebound: boolean)
	if startOfRebound == true then
		print("Entity has started rebounding")
		entity.Config.Movement.Speed = entity.Config.Movement.Speed + 50
		local player = game.Players.LocalPlayer
		if player and player:FindFirstChild("PlayerGui") then
			local flashGui = Instance.new("ScreenGui")
			flashGui.Name = "Flash"
			flashGui.IgnoreGuiInset = true
			flashGui.DisplayOrder = 999998
			flashGui.Parent = player.PlayerGui

			local flashFrame = Instance.new("Frame")
			flashFrame.Size = UDim2.new(1, 0, 1, 0)
			flashFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- Vibrant Blue
			flashFrame.BackgroundTransparency = 0 -- Full visibility instantly
			flashFrame.BorderSizePixel = 0
			flashFrame.Parent = flashGui

			-- Smoothly fade out the flash frame
			local tweenInfo = TweenInfo.new(1, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
			local fadeTween = game:GetService("TweenService"):Create(flashFrame, tweenInfo, {BackgroundTransparency = 1})
			fadeTween:Play()

			fadeTween.Completed:Wait()
			flashGui:Destroy()
			end
	else
		print("Entity has finished rebounding")
		local CameraShaker = require(game.ReplicatedStorage.CameraShaker)
		local camara = game.Workspace.CurrentCamera
		local camShake = CameraShaker.new(Enum.RenderPriority.Camera.Value, function(shakeCf)
			camara.CFrame = camara.CFrame * shakeCf
		end)
		camShake:Start()
		camShake:ShakeOnce(30,16.5,0.1,0.5,0.1,0.5)
		
		local sound5 = Instance.new("Sound")
		sound5.SoundId = "rbxassetid://99570778660066"
		sound5.Volume = 10
		sound5.PlaybackSpeed = 1
		sound5.Parent = workspace
		sound5:Play()
	end
end)

entity:SetCallback("OnDamagePlayer", function(newHealth: number)
	if newHealth <= 0 then
		print("Entity has killed the player")
		local function playSoundSafe(soundObj, timePos, speed, volume)
			if not soundObj or not soundObj.Parent then
				return
			end

			soundObj:Stop()
			soundObj.TimePosition = timePos or 0
			soundObj.PlaybackSpeed = speed or 1
			soundObj.Volume = volume or 1
			soundObj:Play()
		end

		local playerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
		local screenGui = Instance.new("ScreenGui")
		screenGui.Name = "FlashOverlay"
		screenGui.IgnoreGuiInset = true 
		screenGui.Parent = playerGui

		local frame = Instance.new("Frame")
		frame.Size = UDim2.new(1, 0, 1, 0)
		frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		frame.BackgroundTransparency = 0 -- Start invisible
		frame.BorderSizePixel = 0
		frame.Parent = screenGui

		local cue2 = Instance.new("Sound")
		cue2.Parent = game.Workspace
		cue2.Name = "Spawn"
		cue2.SoundId = "rbxassetid://8880765497"
		cue2.Volume = 4
		cue2.TimePosition = 0
		cue2.PlaybackSpeed = 0.08
		cue2:Play()

		local dis = Instance.new('DistortionSoundEffect')
		dis.Level = 1
		dis.Parent = cue2

		local colors = {
			Color3.fromRGB(0, 0, 0),
			Color3.fromRGB(255, 255, 255),
			Color3.fromRGB(255, 0, 0),
			Color3.fromRGB(85, 0, 0),
			Color3.fromRGB(170, 0, 0),
			Color3.fromRGB(120, 120, 120)
		}

		local rebound = Instance.new("ImageLabel")
		rebound.Image = "rbxassetid://12670621692"
		rebound.Size = UDim2.new(0, 600, 0, 600)
		rebound.Position = UDim2.new(0.5, 0, 0.5, 0)
		rebound.AnchorPoint = Vector2.new(0.5, 0.5)
		rebound.Parent = screenGui
		rebound.BackgroundTransparency = 1
		rebound.ResampleMode = Enum.ResamplerMode.Pixelated
		rebound.ImageTransparency = 0
		rebound.ZIndex = 1000

		local c = task.spawn(function()
			while true do
				wait(0.03)				
				frame.BackgroundColor3 = colors[math.random(1, #colors)]
				rebound.ImageColor3 = colors[math.random(1, #colors)]
			end
		end)

		local TweenService = game:GetService("TweenService")
		local rng = Random.new() 
		local tweenInfo = TweenInfo.new(0.02, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

		local a = task.spawn(function()
			while true do
				game.TweenService:Create(rebound, tweenInfo, {
					Position = UDim2.new(rng:NextNumber(0.15, 0.8), 0, rng:NextNumber(0.15, 0.8), 0),
					Rotation = rng:NextNumber(-60, 30),

					Size = UDim2.new(0, rng:NextNumber(500, 300), 0, rng:NextNumber(50, 700))
				}):Play()

				task.wait(0.04)
			end
		end)

		local b = task.spawn(function()
			while true do
				playSoundSafe(cue2, 0.25 + math.random() / 10, math.random(5, 15) / 100, 1)
				task.wait(0.25)
			end
		end)

		wait(math.random(2,2.6))


		local cue25 = Instance.new("Sound")
		cue25.Parent = game.Workspace
		cue25.Name = "Spawn"
		cue25.SoundId = "rbxassetid://5263560566"
		cue25.Volume = 10
		cue25.TimePosition = 0
		cue25.PlaybackSpeed = 1
		cue25:Play()

		task.cancel(c)
		task.cancel(a)
		task.cancel(b)
		local oldBackTween = TweenService:Create(rebound, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(0.5, 0, 0.5, 0),
			Size = UDim2.new(0, 1500, 0, 1700),
			Rotation = 0
		})
		oldBackTween:Play()

		wait(0.5)
		local cac = TweenService:Create(rebound, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			ImageTransparency = 1

		})
		cac:Play()
		frame:Destroy()
		wait(0.2)
		cue25:Destroy()
		wait(0.8)
		frame:Destroy()
		cue2:Destroy()
	else
		print("Entity has damaged the player")
	end
end)

