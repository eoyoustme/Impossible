entity:SetCallback("OnDamagePlayer", function(newHealth: number)
	if newHealth <= 0 then
		print("Entity has killed the player")
		local function playSoundSafe(soundObj, timePos, speed, volume)
			if not soundObj or not soundObj.Parent then
				return
			end

			soundObj:Stop()
			soundObj.TimePosition = timePos or 0
			soundObj.PlaybackSpeed = speed or 1
			soundObj.Volume = volume or 1
			soundObj:Play()
		end

		local playerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
		local screenGui = Instance.new("ScreenGui")
		screenGui.Name = "FlashOverlay"
		screenGui.IgnoreGuiInset = true 
		screenGui.Parent = playerGui

		local frame = Instance.new("Frame")
		frame.Size = UDim2.new(1, 0, 1, 0)
		frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		frame.BackgroundTransparency = 0 -- Start invisible
		frame.BorderSizePixel = 0
		frame.Parent = screenGui

		local cue2 = Instance.new("Sound")
		cue2.Parent = game.Workspace
		cue2.Name = "Spawn"
		cue2.SoundId = "rbxassetid://109790776120081"
		cue2.Volume = 10
		cue2.TimePosition = 0
		cue2.PlaybackSpeed = 1
		cue2:Play()


		local colors = {
			Color3.fromRGB(0, 0, 0),
			Color3.fromRGB(255, 0, 0),
			Color3.fromRGB(255, 0, 0),
			Color3.fromRGB(85, 0, 0),
			Color3.fromRGB(170, 0, 0),
			Color3.fromRGB(120, 120, 120)
		}

		local rebound = Instance.new("ImageLabel")
		rebound.Image = "rbxassetid://109188770255707"
		rebound.Size = UDim2.new(0, 600, 0, 600)
		rebound.Position = UDim2.new(0.5, 0, 0.5, 0)
		rebound.AnchorPoint = Vector2.new(0.5, 0.5)
		rebound.Parent = screenGui
		rebound.BackgroundTransparency = 1
		rebound.ResampleMode = Enum.ResamplerMode.Pixelated
		rebound.ImageTransparency = 0
		rebound.ZIndex = 1000

		local c = task.spawn(function()
			while true do
				wait(0.03)				
				frame.BackgroundColor3 = colors[math.random(1, #colors)]
				rebound.ImageColor3 = colors[math.random(1, #colors)]
			end
		end)

		local TweenService = game:GetService("TweenService")
		local rng = Random.new() 
		local tweenInfo = TweenInfo.new(0.04, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

		local a = task.spawn(function()
			while true do
				game.TweenService:Create(rebound, tweenInfo, {
					Position = UDim2.new(rng:NextNumber(0.15, 0.8), 0, rng:NextNumber(0.15, 0.8), 0),
					Rotation = rng:NextNumber(-60, 30),

					Size = UDim2.new(0, rng:NextNumber(500, 300), 0, rng:NextNumber(50, 700))
				}):Play()

				task.wait(0.05)
			end
		end)

		local b = task.spawn(function()
			while true do
				playSoundSafe(cue2, 0.25 + math.random() / 10, math.random(85, 115) / 100, 1)
				task.wait(0.05)
			end
		end)

		wait(math.random(3, 4))


		local cue25 = Instance.new("Sound")
		cue25.Parent = game.Workspace
		cue25.Name = "Spawn"
		cue25.SoundId = "rbxassetid://5263560896"
		cue25.Volume = 10
		cue25.TimePosition = 0
		cue25.PlaybackSpeed = 1
		cue25:Play()

		task.cancel(c)
		task.cancel(a)
		task.cancel(b)
		local oldBackTween = TweenService:Create(rebound, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(0.5, 0, 0.5, 0),
			Size = UDim2.new(0, 1500, 0, 1700),
			Rotation = 0
		})
		oldBackTween:Play()

		wait(0.5)
		local cac = TweenService:Create(rebound, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			ImageTransparency = 1

		})
		cac:Play()
		frame:Destroy()
		wait(0.2)
		cue25:Destroy()
		wait(0.8)
		frame:Destroy()
		cue2:Destroy()
	else
		print("Entity has damaged the player")
	end
end)

